#!/usr/bin/env bash
# ============================================================
#  gitflow — interactive git CLI
#  Install: cp gitflow ~/.local/bin/ && chmod +x ~/.local/bin/gitflow
# ============================================================

set -euo pipefail

# ── Paths ────────────────────────────────────────────────────
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/gitflow"
CONFIG_FILE="$CONFIG_DIR/config.sh"
TEMPLATES_DIR="$CONFIG_DIR/templates"

# ── Colors ───────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; BOLD='\033[1m'; RESET='\033[0m'

# ── Init config if missing ───────────────────────────────────
init_config() {
  mkdir -p "$CONFIG_DIR" "$TEMPLATES_DIR"
  [[ -f "$CONFIG_FILE" ]] && return

  cat > "$CONFIG_FILE" <<'EOF'
# ============================================================
#  gitflow — configuration
# ============================================================

# Available branch prefixes (space-separated)
BRANCH_PREFIXES=("feature" "fix" "hotfix" "refactor" "chore" "release" "wip")

# Separator in branch names (/ or -)
BRANCH_SEPARATOR="/"

# Branch name casing convention
# "kebab"  → feature/my-branch-name
# "snake"  → feature/my_branch_name
# "lower"  → feature/mybranchname
BRANCH_CASE="kebab"

# Main branch name (main or master)
MAIN_BRANCH="main"

# Auto-push after commit? (true/false)
AUTO_PUSH=true

# Use gitmoji in interactive mode? (true/false)
USE_GITMOJI=true

# Open editor for long commits? (true/false)
USE_EDITOR=false

# Default scope (project, module…) — leave empty to disable
DEFAULT_SCOPE=""

# Common scope names for autocompletion
SCOPES=("api" "auth" "ui" "db" "ci" "config" "docs" "tests")
EOF

  # Commit templates per type
  cat > "$TEMPLATES_DIR/feat.txt"     <<'EOF'
feat({scope}): {message}

{body}

Closes #{issue}
EOF
  cat > "$TEMPLATES_DIR/fix.txt"      <<'EOF'
fix({scope}): {message}

{body}

Fixes #{issue}
EOF
  cat > "$TEMPLATES_DIR/chore.txt"    <<'EOF'
chore({scope}): {message}
EOF
  cat > "$TEMPLATES_DIR/docs.txt"     <<'EOF'
docs({scope}): {message}
EOF
  cat > "$TEMPLATES_DIR/refactor.txt" <<'EOF'
refactor({scope}): {message}
EOF
  cat > "$TEMPLATES_DIR/test.txt"     <<'EOF'
test({scope}): {message}
EOF
  cat > "$TEMPLATES_DIR/ci.txt"       <<'EOF'
ci({scope}): {message}
EOF
  cat > "$TEMPLATES_DIR/style.txt"    <<'EOF'
style({scope}): {message}
EOF
  cat > "$TEMPLATES_DIR/perf.txt"     <<'EOF'
perf({scope}): {message}
EOF
  cat > "$TEMPLATES_DIR/revert.txt"   <<'EOF'
revert: {message}

This reverts commit {hash}.
EOF

  echo -e "${GREEN}✔ Configuration initialized in $CONFIG_DIR${RESET}"
}

# ── Load config ──────────────────────────────────────────────
load_config() {
  init_config
  # shellcheck source=/dev/null
  source "$CONFIG_FILE"
  BRANCH_PREFIXES=("${BRANCH_PREFIXES[@]:-feature fix hotfix refactor chore release wip}")
  BRANCH_SEPARATOR="${BRANCH_SEPARATOR:-/}"
  BRANCH_CASE="${BRANCH_CASE:-kebab}"
  MAIN_BRANCH="${MAIN_BRANCH:-main}"
  AUTO_PUSH="${AUTO_PUSH:-true}"
  USE_GITMOJI="${USE_GITMOJI:-true}"
  SCOPES=("${SCOPES[@]:-}")
}

# ── Require a git repo ───────────────────────────────────────
require_git_repo() {
  if ! git rev-parse --git-dir &>/dev/null; then
    echo -e "${RED}✘ Not inside a git repository.${RESET}" >&2
    exit 1
  fi
}

# ── Selector: fzf if available, else native select ──────────
pick() {
  local prompt="$1"; shift
  local items=("$@")
  if command -v fzf &>/dev/null; then
    printf '%s\n' "${items[@]}" | fzf --prompt="$prompt " --height=40% --border --ansi
  else
    echo -e "${CYAN}$prompt${RESET}"
    select item in "${items[@]}"; do
      [[ -n "$item" ]] && echo "$item" && return
    done
  fi
}

# ── Normalize branch name to chosen convention ───────────────
normalize_branch_name() {
  local name="$1"
  name="${name,,}"
  name="${name// /-}"
  name="${name//[^a-z0-9_\-]/-}"
  if [[ "$BRANCH_CASE" == "snake" ]]; then
    name="${name//-/_}"
  elif [[ "$BRANCH_CASE" == "lower" ]]; then
    name="${name//-/}"
  fi
  echo "$name"
}

# ════════════════════════════════════════════════════════════
#  COMMAND: commit
# ════════════════════════════════════════════════════════════
cmd_commit() {
  require_git_repo

  echo -e "\n${BOLD}── Status ──────────────────────────────────────${RESET}"
  git status --short
  echo ""

  # Commit type
  local commit_types=("feat" "fix" "chore" "refactor" "docs" "test" "ci" "style" "perf" "revert" "wip")
  local type
  type=$(pick "Commit type:" "${commit_types[@]}")
  [[ -z "$type" ]] && { echo -e "${RED}Cancelled.${RESET}"; exit 0; }

  # Scope (optional)
  local scope=""
  if [[ ${#SCOPES[@]} -gt 0 ]]; then
    local scope_choices=("(none)" "${SCOPES[@]}" "(other)")
    local scope_pick
    scope_pick=$(pick "Scope (optional):" "${scope_choices[@]}")
    if [[ "$scope_pick" == "(other)" ]]; then
      read -rp $'\e[36mCustom scope: \e[0m' scope
    elif [[ "$scope_pick" != "(none)" ]]; then
      scope="$scope_pick"
    fi
  else
    read -rp $'\e[36mScope (leave empty to skip): \e[0m' scope
  fi

  # Main message
  local message=""
  while [[ -z "$message" ]]; do
    read -rp $'\e[36mCommit message: \e[0m' message
  done

  # Optional body
  local body=""
  read -rp $'\e[36mBody (optional, Enter to skip): \e[0m' body

  # Issue number
  local issue=""
  read -rp $'\e[36mIssue/PR number (optional): \e[0m' issue

  # Build commit message from template
  local template_file="$TEMPLATES_DIR/${type}.txt"
  local commit_msg

  if [[ -f "$template_file" ]]; then
    commit_msg=$(<"$template_file")
    if [[ -n "$scope" ]]; then
      commit_msg="${commit_msg//\{scope\}/$scope}"
    else
      commit_msg="${commit_msg//(\{scope\})/}"
      commit_msg="${commit_msg//\{scope\}/}"
    fi
    commit_msg="${commit_msg//\{message\}/$message}"
    commit_msg="${commit_msg//\{body\}/$body}"
    if [[ -n "$issue" ]]; then
      commit_msg="${commit_msg//\{issue\}/$issue}"
    else
      commit_msg=$(echo "$commit_msg" | grep -v '{issue}' | sed '/^$/N;/^\n$/d')
    fi
    if [[ -n "${hash:-}" ]]; then
      commit_msg="${commit_msg//\{hash\}/$hash}"
    fi
  else
    if [[ -n "$scope" ]]; then
      commit_msg="${type}(${scope}): ${message}"
    else
      commit_msg="${type}: ${message}"
    fi
    [[ -n "$body" ]] && commit_msg+=$'\n\n'"$body"
    [[ -n "$issue" ]] && commit_msg+=$'\n\nCloses #'"$issue"
  fi

  # Preview
  echo -e "\n${BOLD}── Commit message ──────────────────────────────${RESET}"
  echo -e "${YELLOW}$commit_msg${RESET}"
  echo ""

  read -rp $'\e[36mConfirm? [Y/n]: \e[0m' confirm
  [[ "${confirm,,}" == "n" ]] && { echo -e "${RED}Cancelled.${RESET}"; exit 0; }

  git add --all
  echo -e "${GREEN}✔ git add --all${RESET}"

  if [[ "$USE_GITMOJI" == "true" ]] && command -v gitmoji &>/dev/null; then
    echo -e "${CYAN}↳ Running gitmoji...${RESET}"
    gitmoji -c || true
  else
    git commit -m "$commit_msg"
  fi
  echo -e "${GREEN}✔ Commit done${RESET}"

  if [[ "$AUTO_PUSH" == "true" ]]; then
    local current_branch
    current_branch=$(git branch --show-current)
    echo -e "${CYAN}↳ Pushing to origin/$current_branch...${RESET}"
    git push origin "$current_branch"
    echo -e "${GREEN}✔ Pushed${RESET}"
  else
    read -rp $'\e[36mPush now? [Y/n]: \e[0m' dopush
    if [[ "${dopush,,}" != "n" ]]; then
      local current_branch
      current_branch=$(git branch --show-current)
      git push origin "$current_branch"
      echo -e "${GREEN}✔ Pushed${RESET}"
    fi
  fi
}

# ════════════════════════════════════════════════════════════
#  COMMAND: branch
# ════════════════════════════════════════════════════════════
cmd_branch() {
  require_git_repo

  local prefix
  prefix=$(pick "Branch prefix:" "${BRANCH_PREFIXES[@]}")
  [[ -z "$prefix" ]] && { echo -e "${RED}Cancelled.${RESET}"; exit 0; }

  local raw_name=""
  while [[ -z "$raw_name" ]]; do
    read -rp $'\e[36mBranch name: \e[0m' raw_name
  done

  local name
  name=$(normalize_branch_name "$raw_name")
  local full_branch="${prefix}${BRANCH_SEPARATOR}${name}"

  echo -e "\n${YELLOW}Branch: ${BOLD}$full_branch${RESET}"
  read -rp $'\e[36mCreate and switch? [Y/n]: \e[0m' confirm
  [[ "${confirm,,}" == "n" ]] && { echo -e "${RED}Cancelled.${RESET}"; exit 0; }

  read -rp $'\e[36mBase branch (leave empty = current branch): \e[0m' base
  if [[ -n "$base" ]]; then
    git checkout -b "$full_branch" "$base"
  else
    git checkout -b "$full_branch"
  fi

  echo -e "${GREEN}✔ Branch $full_branch created and active${RESET}"

  read -rp $'\e[36mPush branch to origin? [Y/n]: \e[0m' dopush
  [[ "${dopush,,}" != "n" ]] && git push -u origin "$full_branch" && \
    echo -e "${GREEN}✔ Branch pushed${RESET}"
}

# ════════════════════════════════════════════════════════════
#  COMMAND: quick (your current gitall)
# ════════════════════════════════════════════════════════════
cmd_quick() {
  require_git_repo
  git add --all
  echo -e "${GREEN}✔ git add --all${RESET}"
  if [[ "$USE_GITMOJI" == "true" ]] && command -v gitmoji &>/dev/null; then
    gitmoji -c
  else
    read -rp $'\e[36mQuick commit message: \e[0m' msg
    git commit -m "$msg"
  fi
  local branch
  branch=$(git branch --show-current)
  git push origin "$branch"
  echo -e "${GREEN}✔ Pushed${RESET}"
}

# ════════════════════════════════════════════════════════════
#  COMMAND: templates
# ════════════════════════════════════════════════════════════
cmd_templates() {
  echo -e "\n${BOLD}Available templates in $TEMPLATES_DIR:${RESET}\n"
  for f in "$TEMPLATES_DIR"/*.txt; do
    local name; name=$(basename "$f" .txt)
    echo -e "  ${CYAN}${BOLD}$name${RESET}"
    sed 's/^/    /' "$f"
    echo ""
  done
  echo -e "Edit them with: ${YELLOW}nano $TEMPLATES_DIR/<type>.txt${RESET}"
}

# ════════════════════════════════════════════════════════════
#  COMMAND: config
# ════════════════════════════════════════════════════════════
cmd_config() {
  local editor="${VISUAL:-${EDITOR:-nano}}"
  echo -e "${CYAN}Opening $CONFIG_FILE with $editor...${RESET}"
  "$editor" "$CONFIG_FILE"
}

# ════════════════════════════════════════════════════════════
#  COMMAND: status
# ════════════════════════════════════════════════════════════
cmd_status() {
  require_git_repo
  echo -e "\n${BOLD}── Repo ────────────────────────────────────────${RESET}"
  echo -e "  Branch : ${CYAN}$(git branch --show-current)${RESET}"
  echo -e "  Remote : ${CYAN}$(git remote get-url origin 2>/dev/null || echo 'none')${RESET}"
  echo -e "\n${BOLD}── Status ──────────────────────────────────────${RESET}"
  git status --short
  echo -e "\n${BOLD}── Recent commits ──────────────────────────────${RESET}"
  git log --oneline --decorate --color -8
  echo ""
}

# ════════════════════════════════════════════════════════════
#  HELP
# ════════════════════════════════════════════════════════════
cmd_help() {
  cat <<EOF

${BOLD}gitflow${RESET} — interactive git CLI

${BOLD}USAGE${RESET}
  gitflow <command> [options]

${BOLD}COMMANDS${RESET}
  ${CYAN}commit${RESET}     Guided commit with templates (add → gitmoji → push)
  ${CYAN}quick${RESET}      Quick shortcut: add --all → gitmoji → push  (≈ gitall)
  ${CYAN}branch${RESET}     Create a branch with naming convention
  ${CYAN}status${RESET}     Show status + recent commits
  ${CYAN}templates${RESET}  List and display commit templates
  ${CYAN}config${RESET}     Open the configuration file
  ${CYAN}help${RESET}       Show this help

${BOLD}CONFIGURATION${RESET}
  $CONFIG_FILE

${BOLD}TEMPLATES${RESET}
  $TEMPLATES_DIR/

${BOLD}EXAMPLES${RESET}
  gitflow commit           # full guided commit
  gitflow quick            # your old "gitall"
  gitflow branch           # interactive branch creation
  gitflow status           # repo overview

EOF
}

# ════════════════════════════════════════════════════════════
#  MAIN MENU (no argument)
# ════════════════════════════════════════════════════════════
cmd_menu() {
  local choices=(
    "commit    — Guided commit (add → type → message → push)"
    "quick     — Quick shortcut (gitall)"
    "branch    — Create a branch"
    "status    — Repo status"
    "templates — View commit templates"
    "config    — Edit configuration"
  )
  local choice
  choice=$(pick "gitflow — what do you want to do?" "${choices[@]}")
  local cmd; cmd=$(echo "$choice" | awk '{print $1}')
  "cmd_$cmd"
}

# ════════════════════════════════════════════════════════════
#  ENTRY POINT
# ════════════════════════════════════════════════════════════
main() {
  load_config

  case "${1:-menu}" in
    commit)    cmd_commit    ;;
    quick|q)   cmd_quick     ;;
    branch|b)  cmd_branch    ;;
    status|s)  cmd_status    ;;
    templates) cmd_templates ;;
    config)    cmd_config    ;;
    help|-h|--help) cmd_help ;;
    menu)      cmd_menu      ;;
    *)
      echo -e "${RED}Unknown command: $1${RESET}"
      cmd_help
      exit 1
      ;;
  esac
}

main "$@"
